# ───────────────────────── EcoTi environment ─────────────────────────
# Copy to .env (docker compose reads this automatically).

# --- LLM / AI runtime --------------------------------------------------
# Provider router: stub | ollama | groq
#   stub   -> deterministic canned outputs, NO GPU / NO keys (default, demo-safe)
#   ollama -> local/edge models (offline)
#   groq   -> free cloud heavy reasoning
LLM_PROVIDER=stub
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma2:2b

# --- Django ------------------------------------------------------------
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# --- Postgres + pgvector ----------------------------------------------
POSTGRES_DB=ecoti
POSTGRES_USER=ecoti
POSTGRES_PASSWORD=ecoti
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (channels + celery + bus) ----------------------------------
REDIS_URL=redis://redis:6379/0

# --- Neo4j -------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ecotineo4j
# Set 0 to skip Neo4j and use the in-memory mule graph (zero extra infra)
NEO4J_ENABLED=0

# --- Demo / self-healing toggles --------------------------------------
# Force fraud_graph GNN to fail so the planner reroutes to rule-based (self-heal demo)
FORCE_GNN_FAILURE=0

# --- Frontend ----------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
